FROM rust:1.82-bookworm AS zellij-builder

# Clone and build zellij at pinned commit (has list-panes --json, list-tabs, rename-tab-by-id)
RUN git clone --depth 500 https://github.com/zellij-org/zellij.git /zellij \
    && cd /zellij \
    && git checkout a8d99b64a3fe73284b0954da7daabf04da1c432d \
    && cargo build --release \
    && strip target/release/zellij

FROM ubuntu:24.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates util-linux python3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=zellij-builder /zellij/target/release/zellij /usr/local/bin/

WORKDIR /test
